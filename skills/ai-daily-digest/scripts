async def call_openai(
    prompt: str,
    api_key: str,
    api_base: str,
    model: str
) -> str:
    """Call OpenAI-compatible API with retry logic."""
    normalized_base = api_base.rstrip('/')
    url = f'{normalized_base}/chat/completions'
    
    headers = {
        'Content-Type': 'application/json',
        'Authorization': f'Bearer {api_key}',
    }
    
    data = {
        'model': model,
        'messages': [{'role': 'user', 'content': prompt}],
        'temperature': 0.3,
        'top_p': 0.8,
    }
    
    max_retries = 2
    retry_delays = [0, 1, 3]  # 0s, 1s, 3s delays for retries
    
    for attempt in range(max_retries + 1):
        try:
            async with aiohttp.ClientSession() as session:
                async with session.post(url, json=data, headers=headers, timeout=aiohttp.ClientTimeout(total=900)) as response:
                    if response.status != 200:
                        error_text = await response.text()
                        error_msg = f'OpenAI API error ({response.status}): {error_text[:200]}'
                        if attempt < max_retries and response.status >= 500:
                            print(f'[digest] Retry {attempt + 1}/{max_retries}: {error_msg}', file=sys.stderr)
                            await asyncio.sleep(retry_delays[attempt + 1])
                            continue
                        raise Exception(error_msg)
                    
                    result = await response.json()
                    content = result.get('choices', [{}])[0].get('message', {}).get('content', '')
                    return content if isinstance(content, str) else ''
        except asyncio.TimeoutError as e:
            if attempt < max_retries:
                print(f'[digest] Retry {attempt + 1}/{max_retries}: API timeout, retrying...', file=sys.stderr)
                await asyncio.sleep(retry_delays[attempt + 1])
                continue
            raise Exception(f'OpenAI API timeout after {max_retries + 1} attempts') from e
        except Exception as e:
            if attempt < max_retries and 'timeout' in str(e).lower():
                print(f'[digest] Retry {attempt + 1}/{max_retries}: {str(e)[:100]}', file=sys.stderr)
                await asyncio.sleep(retry_delays[attempt + 1])
                continue
            error_msg = str(e) if str(e) else f'Unknown error: {type(e).__name__}'
            raise Exception(f'OpenAI call failed: {error_msg}') from e
    
    raise Exception('OpenAI API call failed after all retries')

def infer_openai_model(api_base: str) -> str:
    """Infer OpenAI model from API base URL."""
    if 'deepseek' in api_base.lower():
        return 'deepseek-chat'
    return OPENAI_DEFAULT_MODEL

class AIClient:
    """OpenAI-compatible AI client."""
    
    def __init__(self, openai_key: str,
                 openai_base: Optional[str] = None, openai_model: Optional[str] = None):
        self.openai_key = openai_key
        self.openai_base = (openai_base or OPENAI_DEFAULT_API_BASE).rstrip('/')
        self.openai_model = openai_model or infer_openai_model(self.openai_base)
    
    async def call(self, prompt: str) -> str:
        """Call OpenAI-compatible API."""
        return await call_openai(prompt, self.openai_key, self.openai_base, self.openai_model)

def parse_json_response(text: str) -> dict:
    """Parse JSON response, handling markdown code blocks."""
    json_text = text.strip()
    original_text = json_text
    
    if json_text.startswith('```'):
        json_text = re.sub(r'^```(?:json)?\n?', '', json_text)
        json_text = re.sub(r'\n?```$', '', json_text)
    
    try:
        return json.loads(json_text)
    except json.JSONDecodeError as e:
        error_detail = f"at position {e.pos}: {e.msg}" if hasattr(e, 'pos') else str(e)
        print(f'[digest] ⚠️ JSON parse error {error_detail}', file=sys.stderr)
        print(f'[digest] ⚠️ First 200 chars of response: {original_text[:200]}', file=sys.stderr)
        raise ValueError(f"Failed to parse API response as JSON: {error_detail}") from e

