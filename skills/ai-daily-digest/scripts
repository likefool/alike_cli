async def fetch_feed(session: aiohttp.ClientSession, feed: dict) -> List[Article]:
    """Fetch and parse a single RSS feed."""
    try:
        timeout = aiohttp.ClientTimeout(total=FEED_FETCH_TIMEOUT_MS / 1000)
        headers = {
            'User-Agent': 'AI-Daily-Digest/1.0 (RSS Reader)',
            'Accept': 'application/rss+xml, application/atom+xml, application/xml, text/xml, */*',
        }
        
        async with session.get(feed['xmlUrl'], timeout=timeout, headers=headers) as response:
            if response.status != 200:
                raise Exception(f'HTTP {response.status}')
            
            xml = await response.text()
            items = parse_rss_items(xml)
            
            articles = []
            for item in items:
                pub_date = parse_date(item['pub_date']) or datetime.fromtimestamp(0)
                articles.append(Article(
                    title=item['title'],
                    link=item['link'],
                    pub_date=pub_date,
                    description=item['description'],
                    source_name=feed['name'],
                    source_url=feed['htmlUrl'],
                ))
            
            return articles
    except Exception as e:
        msg = str(e)
        if 'abort' not in msg.lower() and 'timeout' not in msg.lower():
            print(f'[digest] ✗ {feed["name"]}: {msg}', file=sys.stderr)
        return []

async def fetch_all_feeds(feeds: List[dict]) -> List[Article]:
    """Fetch all RSS feeds concurrently."""
    all_articles = []
    success_count = 0
    fail_count = 0
    
    async with aiohttp.ClientSession() as session:
        for i in range(0, len(feeds), FEED_CONCURRENCY):
            batch = feeds[i:i + FEED_CONCURRENCY]
            results = await asyncio.gather(*[fetch_feed(session, feed) for feed in batch], return_exceptions=True)
            
            for result in results:
                if isinstance(result, list) and len(result) > 0:
                    all_articles.extend(result)
                    success_count += 1
                else:
                    fail_count += 1
            
            progress = min(i + FEED_CONCURRENCY, len(feeds))
            print(f'[digest] Progress: {progress}/{len(feeds)} feeds processed ({success_count} ok, {fail_count} failed)')
    
    print(f'[digest] Fetched {len(all_articles)} articles from {success_count} feeds ({fail_count} failed)')
    return all_articles

