def humanize_time(pub_date: datetime) -> str:
    """Convert datetime to human-readable relative time."""
    now = datetime.now(pub_date.tzinfo) if pub_date.tzinfo else datetime.now()
    diff = now - pub_date
    
    if diff.days == 0:
        mins = diff.seconds // 60
        if mins < 60:
            return f'{mins} 分鐘前'
        hours = diff.seconds // 3600
        return f'{hours} 小時前'
    
    if diff.days < 7:
        return f'{diff.days} 天前'
    
    return pub_date.strftime('%Y-%m-%d')

def generate_keyword_bar_chart(articles: List[ScoredArticle]) -> str:
    """Generate Mermaid keyword bar chart."""
    kw_count = {}
    for a in articles:
        for kw in a.keywords:
            normalized = kw.lower()
            kw_count[normalized] = kw_count.get(normalized, 0) + 1
    
    sorted_kws = sorted(kw_count.items(), key=lambda x: x[1], reverse=True)[:12]
    
    if not sorted_kws:
        return ''
    
    labels = ', '.join([f'"{k}"' for k, _ in sorted_kws])
    values = ', '.join([str(v) for _, v in sorted_kws])
    max_val = sorted_kws[0][1]
    
    chart = '```mermaid\n'
    chart += 'xychart-beta horizontal\n'
    chart += '    title "高頻關鍵詞"\n'
    chart += f'    x-axis [{labels}]\n'
    chart += f'    y-axis "出現次數" 0 --> {max_val + 2}\n'
    chart += f'    bar [{values}]\n'
    chart += '```\n'
    
    return chart

def generate_category_pie_chart(articles: List[ScoredArticle]) -> str:
    """Generate Mermaid category pie chart."""
    cat_count = {}
    for a in articles:
        cat_count[a.category] = cat_count.get(a.category, 0) + 1
    
    if not cat_count:
        return ''
    
    sorted_cats = sorted(cat_count.items(), key=lambda x: x[1], reverse=True)
    
    chart = '```mermaid\n'
    chart += 'pie showData\n'
    chart += '    title "文章分類分佈"\n'
    for cat, count in sorted_cats:
        meta = CATEGORY_META[cat]
        chart += f'    "{meta["emoji"]} {meta["label"]}" : {count}\n'
    chart += '```\n'
    
    return chart

def generate_ascii_bar_chart(articles: List[ScoredArticle]) -> str:
    """Generate ASCII keyword bar chart."""
    kw_count = {}
    for a in articles:
        for kw in a.keywords:
            normalized = kw.lower()
            kw_count[normalized] = kw_count.get(normalized, 0) + 1
    
    sorted_kws = sorted(kw_count.items(), key=lambda x: x[1], reverse=True)[:10]
    
    if not sorted_kws:
        return ''
    
    max_val = sorted_kws[0][1]
    max_bar_width = 20
    max_label_len = max(len(k) for k, _ in sorted_kws)
    
    chart = '```\n'
    for label, value in sorted_kws:
        bar_len = max(1, round((value / max_val) * max_bar_width))
        bar = '█' * bar_len + '░' * (max_bar_width - bar_len)
        chart += f'{label.ljust(max_label_len)} │ {bar} {value}\n'
    chart += '```\n'
    
    return chart

def generate_tag_cloud(articles: List[ScoredArticle]) -> str:
    """Generate tag cloud."""
    kw_count = {}
    for a in articles:
        for kw in a.keywords:
            normalized = kw.lower()
            kw_count[normalized] = kw_count.get(normalized, 0) + 1
    
    sorted_kws = sorted(kw_count.items(), key=lambda x: x[1], reverse=True)[:20]
    
    if not sorted_kws:
        return ''
    
    return ' · '.join([
        f'**{word}**({count})' if i < 3 else f'{word}({count})'
        for i, (word, count) in enumerate(sorted_kws)
    ])

