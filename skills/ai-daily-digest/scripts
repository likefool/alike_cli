Usage:
  python scripts/digest.py [options]

Options:
  --hours <n>     Time range in hours (default: 48)
  --top-n <n>     Number of top articles to include (default: 15)
  --lang <lang>   Summary language: zh or en (default: zh)
  --output <path> Output file path (default: ./digest-YYYYMMDD.md)
  --help          Show this help

Environment:
  OPENAI_API_KEY   Required. API key for OpenAI or compatible API
  OPENAI_API_BASE  Optional base URL (default: https://api.openai.com/v1)
  OPENAI_MODEL     Optional model name (default: gpt-4o-mini, or deepseek-chat for DeepSeek)

Examples:
  python scripts/digest.py --hours 24 --top-n 10 --lang zh
  python scripts/digest.py --hours 72 --top-n 20 --lang en --output ./my-digest.md
""")
    sys.exit(0)

async def main():
    """Main entry point."""
    args = sys.argv[1:]
    
    if '--help' in args or '-h' in args:
        print_usage()
    
    hours = 48
    top_n = 15
    lang = 'zh'
    output_path = ''
    
    i = 0
    while i < len(args):
        if args[i] == '--hours' and i + 1 < len(args):
            hours = int(args[i + 1])
            i += 2
        elif args[i] == '--top-n' and i + 1 < len(args):
            top_n = int(args[i + 1])
            i += 2
        elif args[i] == '--lang' and i + 1 < len(args):
            lang = args[i + 1]
            i += 2
        elif args[i] == '--output' and i + 1 < len(args):
            output_path = args[i + 1]
            i += 2
        else:
            i += 1
    
    openai_api_key = os.getenv('OPENAI_API_KEY')
    openai_api_base = os.getenv('OPENAI_API_BASE')
    openai_model = os.getenv('OPENAI_MODEL')
    
    if not openai_api_key:
        print('[digest] Error: Missing API key. Set OPENAI_API_KEY.', file=sys.stderr)
        print('[digest] Get API key from OpenAI, DeepSeek, or another OpenAI-compatible provider', file=sys.stderr)
        sys.exit(1)
    
    ai_client = AIClient(
        openai_key=openai_api_key,
        openai_base=openai_api_base,
        openai_model=openai_model,
    )
    
    if not output_path:
        date_str = datetime.now().strftime('%Y%m%d')
        output_path = f'./digest-{date_str}.md'
    
    print('[digest] === AI Daily Digest ===')
    print(f'[digest] Time range: {hours} hours')
    print(f'[digest] Top N: {top_n}')
    print(f'[digest] Language: {lang}')
    print(f'[digest] Output: {output_path}')
    resolved_base = (openai_api_base or OPENAI_DEFAULT_API_BASE).rstrip('/')
    resolved_model = openai_model or infer_openai_model(resolved_base)
    print(f'[digest] AI provider: {resolved_base} (model={resolved_model})')
    print()
    
    print(f'[digest] Step 1/5: Fetching {len(RSS_FEEDS)} RSS feeds...')
    all_articles = await fetch_all_feeds(RSS_FEEDS)
    
    if not all_articles:
        print('[digest] Error: No articles fetched from any feed. Check network connection.', file=sys.stderr)
        sys.exit(1)
    
    print(f'[digest] Step 2/5: Filtering by time range ({hours} hours)...')
    cutoff_time = datetime.now() - timedelta(hours=hours)
    recent_articles = []
    for a in all_articles:
        if a.pub_date:
            pub_date = a.pub_date
            # Remove timezone info for comparison
            if pub_date.tzinfo is not None:
                pub_date = pub_date.replace(tzinfo=None)
            if pub_date > cutoff_time:
                recent_articles.append(a)
    
    print(f'[digest] Found {len(recent_articles)} articles within last {hours} hours')
    
    if not recent_articles:
        print(f'[digest] Error: No articles found within the last {hours} hours.', file=sys.stderr)
        print(f'[digest] Try increasing --hours (e.g., --hours 168 for one week)', file=sys.stderr)
        sys.exit(1)
    
    print(f'[digest] Step 3/5: AI scoring {len(recent_articles)} articles...')
    batch_size = max(10, len(recent_articles) // 4) if len(recent_articles) > 10 else 10
    scores = await score_articles_with_ai(recent_articles, ai_client, batch_size=batch_size)
    
    scored_articles = []
    for i, article in enumerate(recent_articles):
        score_info = scores.get(i, {'relevance': 5, 'quality': 5, 'timeliness': 5, 'category': 'other', 'keywords': []})
        scored_articles.append({
            'article': article,
            'total_score': score_info['relevance'] + score_info['quality'] + score_info['timeliness'],
            'breakdown': score_info,
        })
    
    scored_articles.sort(key=lambda x: x['total_score'], reverse=True)
    top_articles = scored_articles[:top_n]
    
    if top_articles:
        print(f'[digest] Top {top_n} articles selected (score range: {top_articles[-1]["total_score"]} - {top_articles[0]["total_score"]})')
    
    # 💾 Save scoring results
    output_dir = Path(output_path).parent / Path(output_path).stem
    data_dir = output_dir / 'data'
    save_scores_data(data_dir, scores, recent_articles)
    
    print('[digest] Step 4/5: Generating AI summaries...')
    indexed_top = [(i, a['article']) for i, a in enumerate(top_articles)]
    batch_size = max(10, len(top_articles) // 2) if len(top_articles) > 10 else 10
    summaries = await summarize_articles(indexed_top, ai_client, lang, batch_size=batch_size)
    
    # 💾 Save summaries
    save_summaries_data(data_dir, summaries, indexed_top)
    
    final_articles = []
    for i, article_data in enumerate(top_articles):
        a = article_data['article']
        sm = summaries.get(i, {'title_zh': a.title, 'summary': a.description[:200], 'reason': ''})
        
        final_articles.append(ScoredArticle(
            title=a.title,
            link=a.link,
            pub_date=a.pub_date,
            description=a.description,
            source_name=a.source_name,
            source_url=a.source_url,
            score=article_data['total_score'],
            score_breakdown=ScoreBreakdown(
                relevance=article_data['breakdown']['relevance'],
                quality=article_data['breakdown']['quality'],
                timeliness=article_data['breakdown']['timeliness'],
            ),
            category=article_data['breakdown']['category'],
            keywords=article_data['breakdown']['keywords'],
            title_zh=sm['title_zh'],
            summary=sm['summary'],
            reason=sm['reason'],
        ))
    
    print('[digest] Step 5/5: Generating today\'s highlights...')
    highlights = await generate_highlights(final_articles, ai_client, lang, top_n=len(top_articles))
    
    # 💾 Save highlights
    (data_dir / 'highlights.txt').parent.mkdir(parents=True, exist_ok=True)
    (data_dir / 'highlights.txt').write_text(highlights, encoding='utf-8')
    print(f'[digest] 💾 Saved highlights to {data_dir / "highlights.txt"}')
    
    successful_sources = set(a.source_name for a in all_articles)
    
    # 💾 Save metadata
    metadata = {
        'timestamp': datetime.now().isoformat(),
        'hours': hours,
        'top_n': top_n,
        'language': lang,
        'total_feeds': len(RSS_FEEDS),
        'successful_feeds': len(successful_sources),
        'total_articles': len(all_articles),
        'filtered_articles': len(recent_articles),
        'selected_articles': len(final_articles),
        'ai_provider': resolved_base,
        'ai_model': resolved_model,
    }
    save_intermediate_data(data_dir, 'metadata', metadata)
    
    report = generate_digest_report(final_articles, highlights, {
        'total_feeds': len(RSS_FEEDS),
        'success_feeds': len(successful_sources),
        'total_articles': len(all_articles),
        'filtered_articles': len(recent_articles),
        'hours': hours,
        'lang': lang,
    })
    
    Path(output_path).parent.mkdir(parents=True, exist_ok=True)
    Path(output_path).write_text(report, encoding='utf-8')
    
    print()
    print('[digest] ✅ Done!')
    print(f'[digest] 📁 Report: {output_path}')
    print(f'[digest] 📊 Stats: {len(successful_sources)} sources → {len(all_articles)} articles → {len(recent_articles)} recent → {len(final_articles)} selected')
    
    if final_articles:
        print()
        print('[digest] 🏆 Top 3 Preview:')
        for i in range(min(3, len(final_articles))):
            a = final_articles[i]
            print(f'  {i + 1}. {a.title_zh or a.title}')
            print(f'     {a.summary[:80]}...')

if __name__ == '__main__':
    asyncio.run(main())
