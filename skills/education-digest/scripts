def save_intermediate_data(data_dir: Path, name: str, data):
    """Save intermediate data to JSON/JSONL file."""
    data_dir.mkdir(parents=True, exist_ok=True)
    
    if isinstance(data, list):
        # JSONL format for list of dicts
        file_path = data_dir / f'{name}.jsonl'
        with open(file_path, 'w', encoding='utf-8') as f:
            for item in data:
                f.write(json.dumps(item if isinstance(item, dict) else asdict(item), ensure_ascii=False) + '\n')
        print(f'[digest] 💾 Saved {len(data)} records to {file_path}')
    elif isinstance(data, dict):
        # JSON format for dict
        file_path = data_dir / f'{name}.json'
        with open(file_path, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
        print(f'[digest] 💾 Saved to {file_path}')
    else:
        # Text format for strings
        file_path = data_dir / f'{name}.txt'
        with open(file_path, 'w', encoding='utf-8') as f:
            f.write(str(data))
        print(f'[digest] 💾 Saved to {file_path}')

def save_scores_data(data_dir: Path, scores: Dict[int, dict], articles: List[Article]):
    """Save AI scoring results with article info."""
    records = []
    for i, article in enumerate(articles):
        score_info = scores.get(i, {'educational_value': 5, 'accessibility': 5, 'relevance': 5, 'category': 'other', 'keywords': []})
        records.append({
            'index': i,
            'article_title': article.title,
            'source': article.source_name,
            'educational_value': score_info['educational_value'],
            'accessibility': score_info['accessibility'],
            'relevance': score_info['relevance'],
            'total_score': score_info['educational_value'] + score_info['accessibility'] + score_info['relevance'],
            'category': score_info['category'],
            'keywords': score_info['keywords'],
        })
    save_intermediate_data(data_dir, 'scores', records)

def save_summaries_data(data_dir: Path, summaries: Dict[int, dict], articles: List):
    """Save AI summaries with article info."""
    records = []
    for i, (idx, article) in enumerate(articles):
        sm = summaries.get(i, {'title_zh': article.title, 'summary': article.description[:200], 'reason': ''})
        records.append({
            'index': i,
            'article_title_en': article.title,
            'article_title_zh': sm['title_zh'],
            'source': article.source_name,
            'summary': sm['summary'],
            'reason': sm['reason'],
        })
    save_intermediate_data(data_dir, 'summaries', records)

