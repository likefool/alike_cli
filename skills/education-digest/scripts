def generate_digest_report(
    articles: List[ScoredArticle],
    highlights: str,
    stats: dict
) -> str:
    """Generate the final Markdown digest report."""
    now = datetime.now()
    date_str = now.strftime('%Y-%m-%d')
    
    report = f'# 📰 Edu Blog每日精選 — {date_str}\n\n'
    report += f'> 來自 {stats["total_feeds"]} 個頂級 Edu Blog，AI 精選 Top {len(articles)}\n\n'
    
    if highlights:
        report += '## 📝 今日看點\n\n'
        report += f'{highlights}\n\n'
        report += '---\n\n'
    
    if len(articles) >= 3:
        report += '## 🏆 今日必讀\n\n'
        medals = ['🥇', '🥈', '🥉']
        for i in range(min(3, len(articles))):
            a = articles[i]
            medal = medals[i]
            cat_meta = CATEGORY_META[a.category]
            
            report += f'{medal} **{a.title_zh or a.title}**\n\n'
            report += f'[{a.title}]({a.link}) — {a.source_name} · {humanize_time(a.pub_date)} · {cat_meta["emoji"]} {cat_meta["label"]}\n\n'
            report += f'> {a.summary}\n\n'
            if a.reason:
                report += f'💡 **為什麼值得讀**: {a.reason}\n\n'
            if a.keywords:
                report += f'🏷️ {", ".join(a.keywords)}\n\n'
        
        report += '---\n\n'
    
    report += '## 📊 資料概覽\n\n'
    
    report += '| 掃描源 | 抓取文章 | 時間範圍 | 精選 |\n'
    report += '|:---:|:---:|:---:|:---:|\n'
    report += f'| {stats["success_feeds"]}/{stats["total_feeds"]} | {stats["total_articles"]} 篇 → {stats["filtered_articles"]} 篇 | {stats["hours"]}h | **{len(articles)} 篇** |\n\n'
    
    pie_chart = generate_category_pie_chart(articles)
    if pie_chart:
        report += f'### 分類分佈\n\n{pie_chart}'
    
    bar_chart = generate_keyword_bar_chart(articles)
    if bar_chart:
        report += f'### 高頻關鍵詞\n\n{bar_chart}'
    
    ascii_chart = generate_ascii_bar_chart(articles)
    if ascii_chart:
        report += f'<details>\n<summary>📈 純文本關鍵詞圖（終端友善）</summary>\n\n{ascii_chart}</details>\n\n'
    
    tag_cloud = generate_tag_cloud(articles)
    if tag_cloud:
        report += f'### 🏷️ 話題標籤\n\n{tag_cloud}\n\n'
    
    report += '---\n\n'
    
    category_groups = {}
    for a in articles:
        if a.category not in category_groups:
            category_groups[a.category] = []
        category_groups[a.category].append(a)
    
    sorted_cats = sorted(category_groups.items(), key=lambda x: len(x[1]), reverse=True)
    
    global_index = 0
    for cat_id, cat_articles in sorted_cats:
        cat_meta = CATEGORY_META[cat_id]
        report += f'## {cat_meta["emoji"]} {cat_meta["label"]}\n\n'
        
        for a in cat_articles:
            global_index += 1
            score_total = a.score_breakdown.educational_value + a.score_breakdown.accessibility + a.score_breakdown.relevance
            
            report += f'### {global_index}. {a.title_zh or a.title}\n\n'
            report += f'[{a.title}]({a.link}) — **{a.source_name}** · {humanize_time(a.pub_date)} · ⭐ {score_total}/30\n\n'
            report += f'> {a.summary}\n\n'
            if a.keywords:
                report += f'🏷️ {", ".join(a.keywords)}\n\n'
            report += '---\n\n'
    
    report += f'*生成於 {date_str} {now.strftime("%H:%M")} | 掃描 {stats["success_feeds"]} 源 → 獲取 {stats["total_articles"]} 篇 → 精選 {len(articles)} 篇*\n'
    report += '*由「AlikecoolAI」製作💡*\n'
    
    return report

