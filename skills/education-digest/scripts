def strip_html(html: str) -> str:
    """Strip HTML tags and decode entities."""
    text = html
    text = re.sub(r'<[^>]*>', '', text)
    text = text.replace('&amp;', '&')
    text = text.replace('&lt;', '<')
    text = text.replace('&gt;', '>')
    text = text.replace('&quot;', '"')
    text = text.replace('&#39;', "'")
    text = text.replace('&nbsp;', ' ')
    
    text = re.sub(r'&#x([0-9a-fA-F]+);', lambda m: chr(int(m.group(1), 16)), text)
    text = re.sub(r'&#(\d+);', lambda m: chr(int(m.group(1))), text)
    
    return text.strip()

def extract_cdata(text: str) -> str:
    """Extract CDATA content."""
    match = re.search(r'<!\[CDATA\[([\s\S]*?)\]\]>', text)
    return match.group(1) if match else text

def get_tag_content(xml: str, tag_name: str) -> str:
    """Extract tag content from XML."""
    pattern = rf'<{tag_name}[^>]*>([\s\S]*?)</{tag_name}>'
    match = re.search(pattern, xml, re.IGNORECASE)
    if match:
        return extract_cdata(match.group(1)).strip()
    
    self_closing_pattern = rf'<{tag_name}[^>]*/>'
    if re.search(self_closing_pattern, xml, re.IGNORECASE):
        return ''
    
    return ''

def get_attr_value(xml: str, tag_name: str, attr_name: str) -> str:
    """Extract attribute value from XML tag."""
    pattern = rf'<{tag_name}[^>]*\s{attr_name}=["\']([^"\']*)["\'][^>]*/?>i'
    match = re.search(pattern, xml, re.IGNORECASE)
    return match.group(1) if match else ''

def parse_date(date_str: str) -> Optional[datetime]:
    """Parse date string to datetime."""
    if not date_str:
        return None
    
    try:
        dt = datetime.fromisoformat(date_str.replace('Z', '+00:00'))
        return dt
    except (ValueError, AttributeError):
        pass
    
    date_formats = [
        '%a, %d %b %Y %H:%M:%S %z',
        '%Y-%m-%dT%H:%M:%S%z',
        '%Y-%m-%d %H:%M:%S',
        '%Y-%m-%d',
    ]
    
    for fmt in date_formats:
        try:
            return datetime.strptime(date_str, fmt)
        except ValueError:
            continue
    
    return None

def parse_rss_items(xml: str) -> List[dict]:
    """Parse RSS/Atom items from XML."""
    items = []
    
    is_atom = '<feed' in xml and 'xmlns="http://www.w3.org/2005/Atom"' in xml
    
    if is_atom:
        entry_pattern = r'<entry[\s>]([\s\S]*?)</entry>'
        for match in re.finditer(entry_pattern, xml, re.IGNORECASE):
            entry_xml = match.group(1)
            title = strip_html(get_tag_content(entry_xml, 'title'))
            
            link = get_attr_value(entry_xml, 'link[^>]*rel="alternate"', 'href')
            if not link:
                link = get_attr_value(entry_xml, 'link', 'href')
            
            pub_date = get_tag_content(entry_xml, 'published') or get_tag_content(entry_xml, 'updated')
            description = strip_html(get_tag_content(entry_xml, 'summary') or get_tag_content(entry_xml, 'content'))
            
            if title or link:
                items.append({
                    'title': title,
                    'link': link,
                    'pub_date': pub_date,
                    'description': description[:500],
                })
    else:
        item_pattern = r'<item[\s>]([\s\S]*?)</item>'
        for match in re.finditer(item_pattern, xml, re.IGNORECASE):
            item_xml = match.group(1)
            title = strip_html(get_tag_content(item_xml, 'title'))
            link = get_tag_content(item_xml, 'link') or get_tag_content(item_xml, 'guid')
            pub_date = (get_tag_content(item_xml, 'pubDate') or 
                       get_tag_content(item_xml, 'dc:date') or
                       get_tag_content(item_xml, 'date'))
            description = strip_html(
                get_tag_content(item_xml, 'description') or 
                get_tag_content(item_xml, 'content:encoded')
            )
            
            if title or link:
                items.append({
                    'title': title,
                    'link': link,
                    'pub_date': pub_date,
                    'description': description[:500],
                })
    
    return items

