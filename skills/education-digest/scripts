async def summarize_articles(
    articles: List[Tuple[int, Article]],
    ai_client: AIClient,
    lang: str
) -> Dict[int, dict]:
    """Generate summaries for articles."""
    summaries = {}
    
    indexed = [(idx, a.title, a.description, a.source_name, a.link) for idx, a in articles]
    
    batches = [indexed[i:i + BATCH_SIZE] for i in range(0, len(indexed), BATCH_SIZE)]
    
    print(f'[digest] Generating summaries for {len(articles)} articles in {len(batches)} batches')
    
    for i in range(0, len(batches), MAX_CONCURRENT_REQUESTS):
        batch_group = batches[i:i + MAX_CONCURRENT_REQUESTS]
        tasks = []
        
        for batch in batch_group:
            async def summarize_batch(b=batch):
                try:
                    prompt = build_summary_prompt(b, lang)
                    response_text = await ai_client.call(prompt)
                    parsed = parse_json_response(response_text)
                    
                    batch_summaries = {}
                    for result in parsed.get('results', []):
                        batch_summaries[result['index']] = {
                            'title_zh': result.get('titleZh', ''),
                            'summary': result.get('summary', ''),
                            'reason': result.get('reason', ''),
                        }
                    return batch_summaries
                except Exception as e:
                    error_msg = str(e)
                    print(f'[digest] Summary batch failed: {error_msg}', file=sys.stderr)
                    return {item[0]: {'title_zh': item[1], 'summary': item[1], 'reason': ''} for item in b}
            
            tasks.append(summarize_batch())
        
        results = await asyncio.gather(*tasks)
        for summary_dict in results:
            summaries.update(summary_dict)
        
        print(f'[digest] Summary progress: {min(i + MAX_CONCURRENT_REQUESTS, len(batches))}/{len(batches)} batches')
    
    return summaries

