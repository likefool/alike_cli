def build_scoring_prompt(articles: List[Tuple[int, str, str, str]]) -> str:
    """Build prompt for article scoring."""
    articles_list = '\n\n---\n\n'.join([
        f"Index {idx}: [{source}] {title}\n{desc[:300]}"
        for idx, title, desc, source in articles
    ])
    
    return f"""You are an education content curator selecting articles for a daily digest focused on education and learning.

Please evaluate the following articles on three dimensions (1-10 integer scale, 10 being highest) and assign each article a category label and extract 2-4 keywords.

## Scoring Dimensions

### 1. Educational Value (educational_value) - How well does it support learning outcomes?
- 10: Provides deep pedagogical insights, clear learning frameworks, or transformative teaching methods
- 7-9: Contains practical teaching strategies or significant educational research findings
- 4-6: Offers useful but not groundbreaking educational information
- 1-3: Minimal educational value or unclear learning benefits

### 2. Accessibility (accessibility) - How easy is it to understand and implement?
- 10: Clear, well-structured, actionable for educators and learners at all levels
- 7-9: Generally clear with good practical guidance
- 4-6: Understandable but may require additional context or technical knowledge
- 1-3: Complex, unclear, or difficult to implement

### 3. Relevance (relevance) - How relevant is it to current education trends?
- 10: Addresses urgent, emerging education challenges or breakthrough innovations
- 7-9: Relevant to current educational priorities and trends
- 4-6: Relevant to education but not particularly timely
- 1-3: Outdated or tangential to education

## Category Labels (must choose one)
- online-learning: Online learning platforms, MOOCs, digital courses, remote education
- edtech-tools: EdTech tools, software, applications, technology integration in education
- k12-education: K-12 education, curriculum, teaching methods, student assessment
- higher-education: Higher education, university research, academic innovation
- learning-science: Learning science, cognitive psychology, educational research, brain-based learning
- other: Other education-related content

## Keyword Extraction
Extract 2-4 keywords that best represent the article's topic (in English, concise, e.g., "online learning", "AI tutoring", "assessment")

## Articles to Evaluate

{articles_list}

Return strictly in JSON format without markdown code blocks or additional text:
{{
  "results": [
    {{
      "index": 0,
      "educational_value": 8,
      "accessibility": 7,
      "relevance": 9,
      "category": "online-learning",
      "keywords": ["online learning", "course design", "student engagement"]
    }}
  ]
}}"""

async def score_articles_with_ai(
    articles: List[Article],
    ai_client: AIClient
) -> Dict[int, dict]:
    """Score articles using AI."""
    all_scores = {}
    
    indexed = [(i, a.title, a.description, a.source_name) for i, a in enumerate(articles)]
    
    batches = [indexed[i:i + BATCH_SIZE] for i in range(0, len(indexed), BATCH_SIZE)]
    
    print(f'[digest] AI scoring: {len(articles)} articles in {len(batches)} batches')
    
    valid_categories = {'online-learning', 'edtech-tools', 'k12-education', 'higher-education', 'learning-science', 'other'}
    
    for i in range(0, len(batches), MAX_CONCURRENT_REQUESTS):
        batch_group = batches[i:i + MAX_CONCURRENT_REQUESTS]
        tasks = []
        
        for batch in batch_group:
            async def score_batch(b=batch):
                try:
                    prompt = build_scoring_prompt(b)
                    response_text = await ai_client.call(prompt)
                    parsed = parse_json_response(response_text)
                    
                    scores = {}
                    for result in parsed.get('results', []):
                        clamp = lambda v: max(1, min(10, round(v)))
                        category = result.get('category', 'other')
                        if category not in valid_categories:
                            category = 'other'
                        
                        scores[result['index']] = {
                            'educational_value': clamp(result.get('educational_value', 5)),
                            'accessibility': clamp(result.get('accessibility', 5)),
                            'relevance': clamp(result.get('relevance', 5)),
                            'category': category,
                            'keywords': result.get('keywords', [])[:4],
                        }
                    return scores
                except Exception as e:
                    error_msg = str(e)
                    print(f'[digest] Scoring batch failed: {error_msg}', file=sys.stderr)
                    return {item[0]: {'educational_value': 5, 'accessibility': 5, 'relevance': 5, 'category': 'other', 'keywords': []} for item in b}
            
            tasks.append(score_batch())
        
        results = await asyncio.gather(*tasks)
        for score_dict in results:
            all_scores.update(score_dict)
        
        print(f'[digest] Scoring progress: {min(i + MAX_CONCURRENT_REQUESTS, len(batches))}/{len(batches)} batches')
    
    return all_scores

